{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./src_dist",
    "target": "ES6",
    "module": "CommonJS",
    "types": ["node", "bun-types"],
    "strict": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": false,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "public", "client"]
}